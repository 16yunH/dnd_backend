# --- runtime ---
PORT=4100
NODE_ENV=development
LOG_LEVEL=info

# --- cors / frontend ---
# Comma-separated list, or "*" in dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- database ---
# Uncomment to use PrismaStore (PostgreSQL); otherwise JsonStore is used.
# DATABASE_URL=postgresql://dnd:dnd@localhost:5432/dnd?schema=public

# --- LLM ---
# Provider: deepseek | zhipu | ollama
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-flash
LLM_API_KEY=
LLM_BASE_URL=

# --- Embedding ---
# Provider: ollama | openai | deepseek | zhipu
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# --- RAG ---
# JSON dump produced by tools/ingest/ingest.ts; loaded on startup when set.
# Run: npx tsx tools/ingest/ingest.ts ./rules-corpus ./storage/rag-dump.json
RAG_DUMP_PATH=./storage/rag-dump.json
