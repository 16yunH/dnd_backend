# --- runtime ---
PORT=4100
NODE_ENV=development
LOG_LEVEL=info

# --- cors / frontend ---
# Comma-separated list, or "*" in dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- database (phase 2) ---
# DATABASE_URL=postgresql://dnd:dnd@localhost:5432/dnd?schema=public

# --- LLM (phase 4) ---
# Provider: deepseek | zhipu | gemini | ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=

# --- Embedding (phase 4) ---
# Provider: ollama | openai | deepseek | zhipu
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# --- RAG ---
# JSON dump produced by tools/ingest/ingest.ts; loaded on startup when set.
RAG_DUMP_PATH=
